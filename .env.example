# Application
APP_NAME=grc-policy-server
ENVIRONMENT=production
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8500
DEBUG=false
API_BEARER_TOKEN=dummy-token
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false

# Storage
UPLOAD_ROOT=./data/uploads

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_COLLECTION=PolicyChunk
WEAVIATE_EMBEDDED=false

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=granite3.3:8b
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_TIMEOUT_SEC=180

# MongoDB (reserved for future repository backend)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=grc_policy_server
MONGODB_COLLECTION=documents

# Runtime tuning
DOWNLOAD_TIMEOUT_SECONDS=30
MAX_DOWNLOAD_MB=50
EMBED_BATCH_SIZE=32

# Request mutex + Celery upload v2
REQUEST_MUTEX_LOCK_FILE=/tmp/grc_policy_server.request.lock
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_DEFAULT_QUEUE=grc_policy_server.upload
CELERY_TASK_TIMEOUT_SEC=900
CELERY_TASK_SOFT_TIME_LIMIT_SEC=1200
CELERY_TASK_HARD_TIME_LIMIT_SEC=1500
CELERY_WORKER_PING_TIMEOUT_SEC=1
CELERY_ENFORCE_WORKER_PING=false
CELERY_WORKER_CONCURRENCY=null
CELERY_WORKER_POOL=null
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=200
CELERY_WORKER_MAX_MEMORY_PER_CHILD_KB=0
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=true
CELERY_BROKER_POOL_LIMIT=10
CELERY_RESULT_EXPIRES_SEC=86400
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true
CELERY_WORKER_DISABLE_RATE_LIMITS=true

# Docling accelerator (GPU auto-use when available)
DOCLING_ACCELERATOR_DEVICE=auto
DOCLING_ACCELERATOR_THREADS=4
DOCLING_CUDA_USE_FLASH_ATTENTION2=false
