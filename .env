# Application
APP_NAME=grc-policy-server
ENVIRONMENT=production
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8500
DEBUG=false
API_BEARER_TOKEN=dummy-token
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false

# Storage
UPLOAD_ROOT=/Users/navm/projects/grc-policy-server/data/uploads

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_COLLECTION=PolicyChunk
WEAVIATE_EMBEDDED=false

# Ollama
OLLAMA_URL=http://192.168.178.23:11434
OLLAMA_CHAT_MODEL=mistral-nemo:12b
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_TIMEOUT_SEC=180

# MongoDB (reserved for future repository backend)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=grc_policy_server
MONGODB_COLLECTION=documents

# Runtime tuning
DOWNLOAD_TIMEOUT_SECONDS=30
MAX_DOWNLOAD_MB=50
EMBED_BATCH_SIZE=32
